# ============================================================================
#  TEMPLATE per le variabili d'ambiente — copia in ".env" e compila.
#  IL FILE ".env" NON VA MAI COMMITTATO (e' gia' in .gitignore).
#
#  Serve SOLO quando passi al LIVE. In dry-run (paper) NON serve niente di tutto
#  questo: il bot funziona senza chiavi.
#
#  Freqtrade legge queste variabili con il prefisso FREQTRADE__ e doppio "__"
#  come separatore dei livelli del config.
# ============================================================================

# --- Chiavi API Kraken (SOLO per il live) -----------------------------------
# IMPORTANTE: crea la chiave con permesso SOLO "Trading".
# NON dare MAI il permesso di Prelievo/Withdrawal. Aggiungi una IP whitelist.
FREQTRADE__EXCHANGE__KEY=
FREQTRADE__EXCHANGE__SECRET=

# Disattiva il paper trading SOLO quando sei pronto al live.
# FREQTRADE__DRY_RUN=false

# --- FreqUI / API server (cambia le credenziali!) ---------------------------
FREQTRADE__API_SERVER__USERNAME=freqtrader
FREQTRADE__API_SERVER__PASSWORD=cambia_questa_password
FREQTRADE__API_SERVER__JWT_SECRET_KEY=cambia_con_stringa_casuale_lunga
FREQTRADE__API_SERVER__WS_TOKEN=cambia_token_websocket

# --- Telegram (opzionale, per le notifiche/monitoraggio) --------------------
# FREQTRADE__TELEGRAM__ENABLED=true
# FREQTRADE__TELEGRAM__TOKEN=
# FREQTRADE__TELEGRAM__CHAT_ID=
