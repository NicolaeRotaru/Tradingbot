{
    "$schema": "https://schema.freqtrade.io/schema.json",
    "bot_name": "tradingbot-backtest",

    "_commento": "Config SOLO per scaricare dati e fare backtest su Binance (OHLCV abbondante). Kraken espone solo 720 candele storiche, quindi la ricerca si fa qui; dry-run e live girano su Kraken con user_data/config.json. La logica della strategia e' identica.",

    "max_open_trades": 2,
    "stake_currency": "USDT",
    "stake_amount": 20,
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "EUR",

    "dry_run": true,
    "dry_run_wallet": 50,

    "trading_mode": "spot",
    "margin_mode": "",
    "timeframe": "1h",

    "entry_pricing": {
        "price_side": "same",
        "use_order_book": false,
        "order_book_top": 1
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": false,
        "order_book_top": 1
    },

    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT",
            "ETH/USDT",
            "SOL/USDT"
        ],
        "pair_blacklist": []
    },

    "pairlists": [
        { "method": "StaticPairList" }
    ],

    "initial_state": "running",
    "internals": { "process_throttle_secs": 5 }
}
